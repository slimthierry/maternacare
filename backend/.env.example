# MaternaCare Backend - Environment Variables
# Copy this file to .env and adjust values for your environment.

# Application
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://maternacare:maternacare_secret@localhost:5434/maternacare

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=maternacare-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4000

# Webhooks (optional - SIH integration)
WEBHOOK_URL=
WEBHOOK_SECRET=
